.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage/
htmlcov/

# Models / weights (mounted at runtime, never committed)
models/

# Documentation
docs/*
!docs/openapi/
docs/openapi/*
!docs/openapi/*.json
!docs/**/README.md

# Environment files
.env*
!.env.example

# Logs
logs/
*.log
*.log*

# Backup and temporary files
*.bak
*.backup
*.tmp
tmp/
temp/

